APP_SECRET=your_app_secret

# =============================================================================
# OPTIONAL - Telegram Bot (if using Telegram channel)
# =============================================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=z3Agent_bot

