# =============================================================================
# z3-Agent Environment Variables
# Copy this to .env for local development
# For Railway: Set these in the Railway Dashboard > Variables
# =============================================================================

# =============================================================================
# REQUIRED - Must be set for app to work
# =============================================================================

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini-2.5-flash

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_ACCOUNT_ID=your_account_id
VERIFY_TOKEN=your_webhook_verify_token
APP_SECRET=your_app_secret

# =============================================================================
# OPTIONAL - Telegram Bot (if using Telegram channel)
# =============================================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=z3_agent_bot
# TELEGRAM_WEBHOOK_SECRET=optional_webhook_secret

# =============================================================================
# OPTIONAL - Alerting (Telegram notifications for errors)
# =============================================================================

# TELEGRAM_ALERT_CHAT_ID=your_chat_id_for_alerts

# =============================================================================
# OPTIONAL - Override defaults (usually not needed)
# =============================================================================

# RAG Settings
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# RETRIEVAL_K=7

# Reranker Settings
# USE_RERANKER=true
# RERANKER_MODEL=BAAI/bge-reranker-base
# RERANKER_TOP_K=3

# Quality Gate Thresholds
# QUALITY_GATE_THRESHOLD_GOOD=0.5
# QUALITY_GATE_THRESHOLD_MEDIUM=0.0

# LLM Temperatures
# REPLY_TEMPERATURE=0.7
# UNIFIED_PROCESSOR_TEMPERATURE=0.3

# Paths (usually don't need to change)
# REPLY_CONFIG_PATH=content/reply_config1.json
# UNIFIED_PROCESSOR_PROMPT_PATH=prompts/unified_processor_prompt.txt
